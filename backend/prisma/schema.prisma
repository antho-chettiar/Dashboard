// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Artist {
  id                 String            @id @default(cuid())
  name               String
  nationality        String?
  bio                String?
  photoUrl           String?
  active             Boolean           @default(true)
  genres             ArtistGenre[]
  platformMetrics    PlatformMetric[]
  concerts           Concert[]
  audienceDemographics AudienceDemographic[]
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  @@index([name])
  @@index([active])
  @@map("artists")
}

model Genre {
  id         Int               @id @default(autoincrement())
  name       String            @unique
  artists    ArtistGenre[]
  created_at DateTime          @default(now())

  @@map("genres")
}

model ArtistGenre {
  artist   Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId String
  genre    Genre   @relation(fields: [genreId], references: [id], onDelete: Cascade)
  genreId  Int

  @@id([artistId, genreId])
  @@map("artist_genres")
}

model PlatformMetric {
  id              String            @id @default(cuid())
  artist          Artist            @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId        String
  platform        Platform
  metricDate      DateTime          @db.Date
  followers       BigInt            @default(0)
  likes           BigInt            @default(0)
  shares          BigInt            @default(0)
  comments        BigInt            @default(0)
  streams         BigInt            @default(0)
  rogDaily        Decimal?          @db.Decimal(8, 4)
  rogWeekly       Decimal?          @db.Decimal(8, 4)
  rogMonthly      Decimal?          @db.Decimal(8, 4)
  source          MetricSource      @default(API)
  rawSnapshot     Json?
  created_at      DateTime          @default(now())

  @@unique([artistId, platform, metricDate])
  @@index([artistId, platform, metricDate])
  @@index([metricDate])
  @@map("platform_metrics")
}

model Concert {
  id               String            @id @default(cuid())
  artist           Artist            @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId         String
  concertName      String?
  concertDate      DateTime          @db.Date
  city             String
  state            String?
  country          String
  latitude         Decimal?          @db.Decimal(9, 6)
  longitude        Decimal?          @db.Decimal(9, 6)
  venueName        String?
  capacity         Int?
  ticketsSold      Int               @default(0)
  avgTicketPrice   Decimal?          @db.Decimal(10, 2)
  totalRevenue     Decimal?          @db.Decimal(14, 2)
  currency         String            @default("INR")
  notes            String?
  created_at       DateTime          @default(now())

  audienceDemographics AudienceDemographic[]
  @@index([artistId, concertDate])
  @@index([city])
  @@index([country])
  @@map("concerts")
}

model AudienceDemographic {
  id             String            @id @default(cuid())
  artist         Artist?           @relation(fields: [artistId], references: [id], onDelete: SetNull)
  artistId       String?
  concert        Concert?          @relation(fields: [concertId], references: [id], onDelete: SetNull)
  concertId      String?
  dimension      DemographicDimension
  dimensionValue String            @db.VarChar(100)
  percentage     Decimal?          @db.Decimal(5, 2)
  absoluteCount  Int?
  sourcePlatform String?           @db.VarChar(100)
  metricDate     DateTime          @db.Date
  created_at     DateTime          @default(now())

  @@index([artistId])
  @@index([concertId])
  @@index([dimension])
  @@map("audience_demographics")
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  passwordHash    String
  role            UserRole          @default(VIEWER)
  active          Boolean           @default(true)
  refreshTokens   RefreshToken[]
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  YOUTUBE
  SPOTIFY
  APPLE_MUSIC
  REDDIT
  QUORA
}

enum MetricSource {
  API
  EXCEL_IMPORT
}

enum DemographicDimension {
  AGE_GROUP
  GENDER
  GEOGRAPHY
  GENRE
}

enum UserRole {
  ADMIN
  VIEWER
}
